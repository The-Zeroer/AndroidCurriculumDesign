<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:elevation="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 头像 -->
        <ImageView
            android:id="@+id/iv_popup_avatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/avatar_square_border"
            android:scaleType="centerCrop"
            android:padding="3dp" />

        <!-- 姓名 -->
        <TextView
            android:id="@+id/tv_popup_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="张伟"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1F1F1F"
            android:gravity="center" />

        <!-- 邮箱 -->
        <TextView
            android:id="@+id/tv_popup_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="zhang.wei@example.com"
            android:textSize="14sp"
            android:textColor="#757575"
            android:gravity="center" />

        <!-- 分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:background="#E0E0E0" />

        <!-- 附加信息（如账号ID） -->
        <TextView
            android:id="@+id/tv_popup_account_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="账号ID: 1002345"
            android:textSize="13sp"
            android:textColor="#757575"
            android:gravity="center" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>